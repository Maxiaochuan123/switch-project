{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Current",
  "version": "1.0.0",
  "identifier": "com.current.app",
  "build": {
    "beforeDevCommand": "node scripts/check-node-version.mjs && cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin export-contracts && vite --port 1420",
    "beforeBuildCommand": "node scripts/check-node-version.mjs && cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin export-contracts && vite build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Current",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "dragDropEnabled": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5MTMxRDc1MDlGNEVCREUKUldUZTYvUUpkUjBUK1lsYnlOdjY3dDFORys5QlVzTGhBdThrdEU4eXJuT0dSbVFVczZRL0ZBRisK",
      "endpoints": [
        "https://switch-project-latest.vercel.app/api/update/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
